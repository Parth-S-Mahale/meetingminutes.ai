# App Settings
APP_NAME=Meeting Summarizer API
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///./meeting_summarizer.db

# File Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE_MB=100
ALLOWED_AUDIO_EXTENSIONS=[".mp3",".wav",".m4a",".aac",".mp4"]

# Hugging Face / Models
HF_TOKEN=your_huggingface_token_here

# Whisper / ASR
ASR_MODEL_ID=openai/whisper-medium.en
ASR_DEVICE=cpu
ASR_DTYPE=float32
ASR_CHUNK_LENGTH_S=30

# Summarization LLM
SUMMARIZER_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
SUMMARIZER_DEVICE_MAP=auto
SUMMARIZER_LOAD_IN_4BIT=True
MAX_NEW_TOKENS=800
TEMPERATURE=0.2
TOP_P=0.9

# Optional OpenAI fallback if you later want it
OPENAI_API_KEY=